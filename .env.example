# OpenAI API key — required for the AI chatbot
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Resend API key — required for the contact form to send emails
# Create a free account at https://resend.com and verify your domain
# Then create an API key at https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
